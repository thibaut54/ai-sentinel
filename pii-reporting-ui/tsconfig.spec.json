{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/out-tsc/spec",
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@angular/core/testing": ["node_modules/@angular/core/types/testing.d.ts"],
      "@angular/common/http": ["node_modules/@angular/common/types/http.d.ts"],
      "primeng/multiselect": ["node_modules/primeng/types/primeng-multiselect.d.ts"],
      "primeng/types/multiselect": ["node_modules/primeng/types/primeng-types-multiselect.d.ts"],
      "primeng/*": ["node_modules/primeng/*"],
      "@angular/platform-browser/animations": ["node_modules/@angular/platform-browser/fesm2022/animations.mjs"]
    }
  },
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}
