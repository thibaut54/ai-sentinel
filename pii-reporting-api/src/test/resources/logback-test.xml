<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Reduce log level for controllers during tests -->
    <!-- Expected errors in tests will not be logged with stacktrace -->
    <logger name="pro.softcom.aisentinel.infrastructure.confluence.adapter.in" level="WARN"/>

    <!-- POI/PDFBox émettent des milliers de WARN de fidélité de style sur les
         fichiers legacy du corpus ; sans impact sur le texte extrait -> bruit. -->
    <logger name="org.apache.poi" level="ERROR"/>
    <logger name="org.apache.pdfbox" level="ERROR"/>
    <logger name="org.apache.fontbox" level="ERROR"/>

    <!-- Default configuration for other packages -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
